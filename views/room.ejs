<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Room <%= roomCode %> - AetherMeet</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <script>
    window.roomCode = "<%= roomCode %>";
  </script>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Emoji:wght@300..700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/compiled.css">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            mono: [
              "JetBrains Mono",
              "Consolas",
              "Monaco",
              "Courier New",
              "monospace",
            ],
            sans: ["Outfit", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
            display: ["Space Grotesk", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"]
          },
          spacing: {
            '4.5': '1.125rem',
            '5.5': '1.375rem',
            '6.5': '1.625rem'
          }
        },
      },
    };
  </script>
  <style>
    /* Emoji font styling */
    .emoji,
    #themeIcon,
    [data-emoji],
    .theme-toggle-btn span,
    .pdf-export-btn span,
    button span[role="img"],
    [aria-label*="emoji"] {
      font-family: "Noto Emoji", "Apple Color Emoji", "Segoe UI Emoji", sans-serif !important;
      font-variation-settings: "wght" 400;
    }
    
    h1, h2, h3, h4 {
      font-family: 'Space Grotesk', sans-serif !important;
    }
  </style>
</head>

<body class="bg-white text-black font-sans h-screen flex flex-col transition-colors duration-300 dark:bg-zinc-950 dark:text-white">
  <!-- Theme Toggle -->
  <div class="fixed top-4 right-4 md:top-6 md:right-6 z-50 flex gap-2">
      <button id="themeToggle" class="btn-brutal btn-brutal-white px-3 py-2 md:px-4 md:py-2.5 text-xs md:text-sm">
          <span id="themeText">DARK</span>
      </button>
  </div>

  <!-- Room Password Lock Modal -->
  <div id="roomPasswordLockModal" class="fixed inset-0 bg-white dark:bg-zinc-950 z-50 flex items-center justify-center hidden">
    <div class="modal-content-swiss max-w-md w-full mx-4">
      <h3 class="text-2xl font-extrabold uppercase font-display tracking-wide mb-6 text-black dark:text-white">Enter Room Password</h3>
      <p class="mb-6 text-sm text-gray-600 dark:text-gray-400 font-mono">
        This is an authenticated room. Please enter the password to open the chat.
      </p>
      <form id="roomPasswordLockForm" class="space-y-4">
        <div>
          <label for="lockPrimaryPassword" class="block text-xs font-bold uppercase tracking-wider mb-2 text-black dark:text-white">Primary Password</label>
          <input type="password" id="lockPrimaryPassword" name="primaryPassword" required
            class="input-brutal w-full px-4 py-3"
            placeholder="••••••••" />
        </div>
        <div id="lockSecondaryPasswordGroup" class="hidden">
          <label for="lockSecondaryPassword" class="block text-xs font-bold uppercase tracking-wider mb-2 text-black dark:text-white">Secondary Password</label>
          <input type="password" id="lockSecondaryPassword" name="secondaryPassword"
            class="input-brutal w-full px-4 py-3"
            placeholder="••••••••" />
        </div>
        <div id="lockError" class="bg-red-100 border-2 border-red-500 text-red-800 p-3 text-sm font-mono hidden mb-4"></div>
        <button type="submit"
          class="btn-brutal btn-brutal-primary w-full py-3.5 mt-2 font-bold uppercase tracking-wide">
          Unlock Chat
        </button>
      </form>
    </div>
  </div>

  <!-- Toast Notification Container -->
  <div id="toastContainer" class="fixed top-6 right-6 z-50 flex flex-col space-y-2 pointer-events-none"></div>

  <!-- Export Chat Modal -->
  <div id="exportChatModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
    <div class="modal-content-swiss max-w-md w-full mx-4">
      <h3 class="text-2xl font-bold uppercase font-display mb-6 text-black dark:text-white">
        Export Chat
      </h3>
      <p class="mb-6 text-gray-700 dark:text-gray-300 font-mono text-sm">
        How would you like to export the chat history?
      </p>
      <div class="space-y-4">
        <button id="exportDownloadBtn"
          class="btn-brutal btn-brutal-secondary w-full px-6 py-3 font-bold text-sm">
          Download PDF to Device
        </button>
        <button id="exportToNotesBtn"
          class="btn-brutal btn-brutal-primary w-full px-6 py-3 font-bold text-sm">
          Save PDF to Notes App
        </button>
        <button id="cancelExportBtn"
          class="btn-brutal btn-brutal-white w-full px-6 py-3 font-bold text-sm">
          Cancel
        </button>
      </div>
    </div>
  </div>
  
  <!-- Room Header -->
  <header class="px-6 py-4 flex flex-col md:flex-row justify-between items-start md:items-center space-y-4 md:space-y-0">
    <div class="flex-1">
      <h1 id="roomName" class="text-2xl md:text-3xl font-extrabold font-display text-black dark:text-white">
        Room <%= roomCode %>
      </h1>
      <p id="roomDescription" class="text-sm text-gray-600 dark:text-gray-400 font-mono mt-1"></p>
      <div class="flex flex-wrap gap-4 mt-3 text-xs font-mono">
        <span id="roomCode" class="bg-black text-white px-2 py-1 font-bold">Code: <%= roomCode %></span>
        <span id="memberCount" class="font-bold text-gray-700 dark:text-gray-300">Members: 0</span>
        <span id="ownerInfo" class="font-bold text-gray-700 dark:text-gray-300">Owner: -</span>
      </div>
    </div>
    <div class="flex space-x-3">
      <button id="shareLinkBtn"
        class="btn-brutal btn-brutal-secondary px-4 py-2 text-sm">
        🔗 Share Link
      </button>
      <button id="exportPdfBtn"
        class="btn-brutal btn-brutal-white px-4 py-2 text-sm">
        📄 Export PDF
      </button>
      <button id="leaveRoomBtn"
        class="btn-brutal btn-brutal-danger px-4 py-2 text-sm">
        Leave Room
      </button>
    </div>
  </header>

  <!-- Room Content -->
  <div class="flex-1 flex overflow-hidden">
    <!-- Member List Sidebar -->
    <aside class="w-64 bg-gray-50 dark:bg-zinc-900 border-r-4 border-black dark:border-white p-4 overflow-y-auto scrollbar-brutal flex flex-col">
      <h3 class="text-lg font-bold font-display uppercase mb-4 text-black dark:text-white">
        Members
      </h3>
      <div id="membersList" class="space-y-2 flex-1">
        <!-- Members will be populated by JavaScript -->
      </div>

      <!-- Pending Admissions -->
      <div id="pendingAdmissions" class="mt-8 pt-4 border-t-2 border-black dark:border-white hidden">
        <h4 class="text-md font-bold font-display uppercase mb-4 text-black dark:text-white">
          Pending Admissions
        </h4>
        <div id="pendingList" class="space-y-2">
          <!-- Pending admissions will be populated by JavaScript -->
        </div>
      </div>
    </aside>

    <!-- Chat Area -->
    <main class="flex-1 flex flex-col bg-white dark:bg-zinc-950">
      <!-- Chat Messages -->
      <div id="chatMessages" class="flex-1 p-6 overflow-y-auto scrollbar-brutal space-y-4">
        <!-- Messages will be populated by JavaScript -->
      </div>

      <!-- Chat Input -->
      <div class="bg-gray-50 dark:bg-zinc-900 border-t-4 border-black dark:border-white p-4">
        <!-- Media Upload Progress -->
        <div id="uploadProgress"
          class="hidden bg-blue-100 border-2 border-blue-500 p-3 mb-3 text-blue-800 font-mono text-sm"
          style="box-shadow: 2px 2px 0px 0px #1e40af">
          <div class="flex items-center justify-between">
            <span id="uploadStatus" class="font-bold">Uploading...</span>
            <div class="w-32 bg-blue-200 border border-blue-400 h-2">
              <div id="uploadBar" class="bg-blue-600 h-full w-0 transition-all duration-300"></div>
            </div>
          </div>
        </div>

        <!-- Audio Recording Interface -->
        <div id="audioRecording" class="hidden bg-red-100 border-2 border-red-500 p-4 mb-3"
          style="box-shadow: 2px 2px 0px 0px #dc2626">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></div>
              <span class="text-red-800 font-bold text-sm uppercase tracking-wide">Recording</span>
              <span id="recordingTime" class="text-red-600 font-mono text-sm">00:00</span>
            </div>
            <div class="flex space-x-2">
              <button id="stopRecording"
                class="btn-brutal btn-brutal-danger px-4 py-2 text-xs">
                Stop
              </button>
              <button id="cancelRecording"
                class="btn-brutal btn-brutal-white px-4 py-2 text-xs text-black">
                Cancel
              </button>
            </div>
          </div>
        </div>

        <!-- Reply Preview Container -->
        <div id="replyPreviewContainer" class="hidden bg-gray-100 dark:bg-zinc-800 border-l-4 border-yellow-400 p-2 mb-3 flex justify-between items-start" style="box-shadow: 2px 2px 0px 0px var(--shadow-color)">
          <div class="flex-1 overflow-hidden">
            <div class="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">Replying to <span id="replyPreviewUsername" class="text-black dark:text-white"></span></div>
            <div id="replyPreviewContent" class="text-sm font-mono text-black dark:text-white truncate mt-1"></div>
          </div>
          <button id="cancelReplyBtn" class="ml-2 text-gray-500 hover:text-red-500 font-bold px-2">✕</button>
        </div>

        <!-- Message Input -->
        <div class="flex space-x-2 items-center">
          <!-- Media Buttons -->
          <div class="flex gap-3">
            <label for="mediaUpload"
              class="btn-brutal btn-brutal-primary px-3 py-3 text-sm cursor-pointer hover:opacity-90 font-mono"
              title="Upload File">
              📁
            </label>
            <input type="file" id="mediaUpload" class="hidden" accept="image/*,video/*,.pdf,.txt,.doc,.docx" multiple />

            <button id="audioRecordBtn"
              class="btn-brutal btn-brutal-danger px-3 py-3 text-sm"
              title="Record Voice">
              🎤
            </button>
          </div>

          <!-- Text Input Form -->
          <form id="messageForm" class="flex flex-1 space-x-2 items-center">
            <input type="text" id="messageInput" placeholder="Type your message..." maxlength="1000"
              class="input-brutal flex-1 px-4 py-3" />
            <button type="submit"
              class="btn-brutal btn-brutal-black px-6 py-3 text-sm font-bold">
              Send
            </button>
          </form>
        </div>
      </div>
    </main>
  </div>

  <!-- Share Link Modal -->
  <div id="shareLinkModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
    <div class="modal-content-swiss max-w-md w-full mx-4 transform transition-all duration-300">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-2xl md:text-3xl font-extrabold uppercase font-display text-black dark:text-white">
          🔗 Share Room Link
        </h3>
        <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
      </div>
      <div class="space-y-6">
        <p class="text-gray-700 dark:text-gray-300 font-extrabold text-sm uppercase tracking-wider">
          📤 Share this link to invite others:
        </p>
        <div class="bg-gray-100 dark:bg-zinc-800 border-2 border-black dark:border-white p-4 font-mono text-sm break-all text-black dark:text-white">
          <span id="shareLink" class="font-bold"></span>
        </div>
        <div class="flex space-x-3">
          <button id="copyLinkBtn"
            class="btn-brutal btn-brutal-secondary flex-1 py-3 text-sm font-bold">
            📋 Copy Link
          </button>
          <button id="copyCodeBtn"
            class="btn-brutal btn-brutal-accent flex-1 py-3 text-sm font-bold">
            📄 Copy Code
          </button>
        </div>
        <div class="bg-yellow-100 border-2 border-yellow-500 p-3" style="box-shadow: 3px 3px 0px #f59e0b">
          <p class="text-xs text-yellow-800 font-bold uppercase font-mono">
            ⚠️ Note: Users will still need to enter the room password!
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Leave Room Options Modal (for owners) -->
  <div id="leaveRoomModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
    <div class="modal-content-swiss max-w-md w-full mx-4">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-2xl font-bold font-display uppercase text-black dark:text-white">
          Leave Room Options
        </h3>
        <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
      </div>
      <p class="text-gray-600 dark:text-gray-400 mb-6 font-mono text-sm">As the room owner, you can choose to:</p>
      <div class="space-y-4">
        <button id="destroyRoomBtn"
          class="btn-brutal btn-brutal-danger w-full px-6 py-3 font-bold">
          End Room for Everyone
        </button>
        <button id="transferOwnershipBtn"
          class="btn-brutal btn-brutal-white w-full px-6 py-3 font-bold text-black dark:text-white">
          Transfer Ownership & Leave
        </button>
        <button id="cancelLeaveBtn"
          class="btn-brutal btn-brutal-white w-full px-6 py-3 font-bold text-black dark:text-white">
          Cancel
        </button>
      </div>
    </div>
  </div>

  <!-- Admission Request Modal -->
  <div id="admissionModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
    <div class="modal-content-swiss max-w-md w-full mx-4">
      <h3 class="text-2xl font-bold font-display uppercase mb-6 text-black dark:text-white">
        New Admission Request
      </h3>
      <div id="admissionDetails" class="mb-6 font-mono text-sm text-gray-700 dark:text-gray-300"></div>
      <div id="admissionActions" class="space-y-3">
        <!-- Actions will be populated based on admission type -->
      </div>
    </div>
  </div>

  <!-- Demo Room Share Modal -->
  <div id="demoShareModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
    <div class="modal-content-swiss max-w-md w-full mx-4">
      <h2 class="text-2xl font-extrabold font-display uppercase mb-4 text-black dark:text-white">
        Demo Room Created! 🎉
      </h2>
      <p class="text-gray-700 dark:text-gray-300 mb-6 text-sm font-mono">
        Share this room with others using the link or room code below:
      </p>

      <div class="space-y-4">
        <div>
          <label class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Room Code:</label>
          <div class="flex items-center">
            <input id="demoRoomCodeInput" type="text" readonly
              class="input-brutal flex-1 p-3 font-mono bg-gray-50" value="<%= roomCode %>" />
            <button id="demoCopyCodeBtn" class="ml-2 btn-brutal btn-brutal-primary px-4 py-3 font-bold text-sm">
              COPY
            </button>
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Share Link:</label>
          <div class="flex items-center">
            <input id="demoShareLinkInput" type="text" readonly
              class="input-brutal flex-1 p-3 font-mono text-xs bg-gray-50" />
            <button id="demoCopyLinkBtn"
              class="ml-2 btn-brutal btn-brutal-secondary px-4 py-3 font-bold text-sm">
              COPY
            </button>
          </div>
        </div>
      </div>

      <div class="mt-6 flex justify-end">
        <button id="closeDemoModal" class="btn-brutal btn-brutal-white px-6 py-2 text-sm font-bold text-black dark:text-white">
          CLOSE
        </button>
      </div>
    </div>
  </div>

  <!-- Connection Status - Socket.IO Indicator -->
  <div id="connectionStatus" class="socket-status" title="Socket.IO connection status"></div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const roomCode = "<%= roomCode %>";
  </script>
  <script src="/js/room.js"></script>
  <script>
    // Theme toggle functionality
    const themeToggle = document.getElementById('themeToggle');
    const themeText = document.getElementById('themeText');
    const currentTheme = localStorage.getItem("theme") || "light";

    // Apply theme on page load
    if (currentTheme === "dark") {
      document.documentElement.classList.add("dark");
      if (themeText) themeText.textContent = 'LIGHT';
    }

    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const isDark = document.documentElement.classList.contains('dark');
            if (isDark) {
                document.documentElement.classList.remove('dark');
                themeText.textContent = 'DARK';
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                themeText.textContent = 'LIGHT';
                localStorage.setItem('theme', 'dark');
            }
        });
    }

    // Demo room functionality
    const isDemo =
      new URLSearchParams(window.location.search).get("demo") === "true";

    if (isDemo) {
      // Show demo share modal
      const modal = document.getElementById("demoShareModal");
      const shareLink =
        window.location.origin + window.location.pathname + "?demo=true";
      document.getElementById("demoShareLinkInput").value = shareLink;
      modal.classList.remove("hidden");
    }

    // Copy functionality
    document
      .getElementById("demoCopyCodeBtn")
      .addEventListener("click", () => {
        const input = document.getElementById("demoRoomCodeInput");
        const code = input.value;

        // Try modern clipboard API first
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard
            .writeText(code)
            .then(() => {
              updateButtonSuccess(
                "demoCopyCodeBtn",
                "btn-brutal-primary",
                "bg-green-500"
              );
            })
            .catch(() => {
              fallbackCopy(
                input,
                "demoCopyCodeBtn",
                "btn-brutal-primary",
                "bg-green-500"
              );
            });
        } else {
          fallbackCopy(
            input,
            "demoCopyCodeBtn",
            "btn-brutal-primary",
            "bg-green-500"
          );
        }
      });

    document
      .getElementById("demoCopyLinkBtn")
      .addEventListener("click", () => {
        const input = document.getElementById("demoShareLinkInput");
        const link = input.value;

        // Try modern clipboard API first
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard
            .writeText(link)
            .then(() => {
              updateButtonSuccess(
                "demoCopyLinkBtn",
                "btn-brutal-secondary",
                "bg-green-500"
              );
            })
            .catch(() => {
              fallbackCopy(
                input,
                "demoCopyLinkBtn",
                "btn-brutal-secondary",
                "bg-green-500"
              );
            });
        } else {
          fallbackCopy(
            input,
            "demoCopyLinkBtn",
            "btn-brutal-secondary",
            "bg-green-500"
          );
        }
      });

    function fallbackCopy(input, btnId, originalClass, successClass) {
      input.select();
      try {
        const successful = document.execCommand("copy");
        if (successful) {
          updateButtonSuccess(btnId, originalClass, successClass);
        }
      } catch (err) {
        console.error("Fallback copy failed:", err);
      }
    }

    function updateButtonSuccess(btnId, originalClass, successClass) {
      const btn = document.getElementById(btnId);
      const originalText = btn.textContent;
      btn.textContent = "COPIED!";
      btn.classList.add(successClass);
      btn.classList.remove(originalClass);

      setTimeout(() => {
        btn.textContent = originalText;
        btn.classList.remove(successClass);
        btn.classList.add(originalClass);
      }, 2000);
    }

    document
      .getElementById("closeDemoModal")
      .addEventListener("click", () => {
        document.getElementById("demoShareModal").classList.add("hidden");
      });
  </script>
</body>

</html>
