<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Personal Notes - AetherMeet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Emoji:wght@300..700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/compiled.css">
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              mono: [
                "JetBrains Mono",
                "Consolas",
                "Monaco",
                "Courier New",
                "monospace",
              ],
              sans: ["Outfit", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
              display: ["Space Grotesk", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"]
            },
            spacing: {
              '4.5': '1.125rem',
              '5.5': '1.375rem',
              '6.5': '1.625rem'
            }
          },
        },
      };
    </script>
    <style>
      /* Emoji font styling */
      .emoji,
      #themeIcon,
      [data-emoji],
      .theme-toggle-btn span,
      .pdf-export-btn span,
      button span[role="img"],
      [aria-label*="emoji"] {
        font-family: "Noto Emoji", "Apple Color Emoji", "Segoe UI Emoji", sans-serif !important;
        font-variation-settings: "wght" 400;
      }
      
      h1, h2, h3, h4 {
        font-family: 'Space Grotesk', sans-serif !important;
      }

      /* Local Toast Overrides for Notes Page */
      .toast {
        position: fixed;
        top: 80px;
        right: 20px;
        min-width: 300px;
        max-width: 500px;
        padding: 16px 20px;
        z-index: 9999;
        animation: slideIn 0.3s ease-out;
        font-weight: 700;
      }

      @keyframes slideIn {
        from {
          transform: translateX(400px);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }

      @keyframes slideOut {
        from {
          transform: translateX(0);
          opacity: 1;
        }
        to {
          transform: translateX(400px);
          opacity: 0;
        }
      }

      .toast.hiding {
        animation: slideOut 0.3s ease-in forwards;
      }
    </style>
  </head>
  <body class="bg-white text-black font-sans min-h-screen transition-colors duration-300 dark:bg-zinc-950 dark:text-white">
    <!-- Theme Toggle -->
    <div class="fixed top-4 right-4 z-50">
      <button id="themeToggle" class="btn-brutal btn-brutal-white px-4 py-2 text-sm">
        <span id="themeText">DARK</span>
      </button>
    </div>

    <!-- Header -->
    <header class="px-6 py-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center flex-wrap gap-4">
        <div class="flex items-center space-x-4">
          <div class="w-8 h-8 bg-black dark:bg-white" style="border: 2px solid var(--border-color);"></div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight font-display">Personal Notes</h1>
            <p class="text-sm text-gray-600 dark:text-gray-400 font-mono">Secure password-protected notes</p>
          </div>
        </div>
        <div class="flex items-center space-x-4">
          <a href="/dashboard" class="btn-brutal btn-brutal-white px-6 py-2 text-sm">
            Dashboard
          </a>
          <button id="logoutBtn" class="btn-brutal btn-brutal-black px-6 py-2 text-sm">
            Logout
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-6xl mx-auto px-6 py-8">
      <!-- Welcome Section -->
      <div class="card-brutal p-6 mb-8">
        <h2 class="text-xl font-bold mb-2 font-display">
          Welcome, <span id="welcomeUser" class="font-extrabold">User</span>!
        </h2>
        <p class="text-gray-600 dark:text-gray-400 text-sm">
          Create secure notes protected by dictionary passwords. Same security model as your chat rooms.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <button id="createNoteBtn" class="btn-brutal btn-brutal-black p-6 text-left flex flex-col justify-between h-full w-full">
          <div>
            <h3 class="font-bold text-xl mb-2 text-white font-display">◉ Create Note</h3>
            <p class="text-sm text-gray-300">
              Write a new password-protected note
            </p>
          </div>
        </button>

        <button id="accessNoteBtn" class="btn-brutal btn-brutal-white p-6 text-left flex flex-col justify-between h-full w-full">
          <div>
            <h3 class="font-bold text-xl mb-2 text-black dark:text-white font-display">▣ Access Note</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">Enter note code and passwords</p>
          </div>
        </button>

        <button id="myNotesBtn" class="btn-brutal btn-brutal-accent p-6 text-left flex flex-col justify-between h-full w-full">
          <div>
            <h3 class="font-bold text-xl mb-2 text-black font-display">
              ● My Notes List
            </h3>
            <p class="text-sm text-gray-800">Browse all your saved notes</p>
          </div>
        </button>
      </div>

      <!-- Note Display Area -->
      <div id="noteDisplay" class="hidden card-brutal p-6 mb-8">
        <div class="flex justify-between items-center mb-6">
          <h3 id="noteTitle" class="text-2xl font-bold font-display text-black dark:text-white"></h3>
          <div class="flex space-x-2">
            <button id="editNoteBtn" class="btn-brutal btn-brutal-primary px-4 py-2 text-sm">
              Edit
            </button>
            <button id="deleteNoteBtn" class="btn-brutal btn-brutal-danger px-4 py-2 text-sm">
              Delete
            </button>
          </div>
        </div>
        <div id="noteContent" class="bg-gray-50 dark:bg-zinc-800 border-2 border-black dark:border-white p-4 font-mono text-sm whitespace-pre-wrap min-h-[200px] text-black dark:text-white"></div>
        <div class="mt-4 text-xs text-gray-500 font-mono">
          <span id="noteInfo"></span>
        </div>
      </div>
    </main>

    <!-- Create Note Modal -->
    <div id="createNoteModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
      <div class="modal-content-swiss max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto transform transition-all duration-300">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl md:text-3xl font-extrabold uppercase font-display text-black dark:text-white">
            Create New Note
          </h3>
          <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
        </div>
        <form id="createNoteForm" class="space-y-5">
          <div>
            <label for="noteTitle" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">📋 Note Title:</label>
            <input type="text" id="noteTitle" name="title" required maxlength="100" class="input-brutal w-full px-4 py-3" placeholder="Enter your note title" />
          </div>
          <div>
            <label for="noteContent" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Content:</label>
            <textarea id="noteContent" name="content" required maxlength="10000" rows="8" class="input-brutal w-full px-4 py-3" placeholder="Write your note content here..."></textarea>
          </div>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label for="notePrimaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">🔑 Primary Password:</label>
              <input type="text" id="notePrimaryPassword" name="primaryPassword" required class="input-brutal w-full px-4 py-3" placeholder="Dictionary word" />
              <small class="text-gray-500 text-xs font-mono mt-1 block">Must be a valid dictionary word</small>
            </div>
            <div>
              <label for="noteSecondaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Secondary Password (Optional):</label>
              <input type="text" id="noteSecondaryPassword" name="secondaryPassword" class="input-brutal w-full px-4 py-3" placeholder="Dictionary word" />
              <small class="text-gray-500 text-xs font-mono mt-1 block">Optional extra security</small>
            </div>
          </div>
          <button type="submit" class="btn-brutal btn-brutal-primary w-full py-4 mt-2 font-bold text-base">
            Create Note
          </button>
        </form>
        <div id="createNoteError" class="hidden bg-red-100 border-2 border-red-500 text-red-800 p-4 mt-4 font-mono text-sm"></div>
      </div>
    </div>

    <!-- Access Note Modal -->
    <div id="accessNoteModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
      <div class="modal-content-swiss max-w-md w-full mx-4">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl font-extrabold uppercase font-display text-black dark:text-white">
            Access Note
          </h3>
          <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
        </div>
        <form id="accessNoteForm" class="space-y-4">
          <div>
            <label for="accessNoteCode" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Note Code:</label>
            <input type="text" id="accessNoteCode" name="noteCode" required maxlength="6" class="input-brutal w-full px-4 py-3 uppercase" placeholder="ABC123" />
          </div>
          <div>
            <label for="accessPrimaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Primary Password:</label>
            <input type="text" id="accessPrimaryPassword" name="primaryPassword" required class="input-brutal w-full px-4 py-3" placeholder="Dictionary word" />
          </div>
          <div>
            <label for="accessSecondaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Secondary Password (if set):</label>
            <input type="text" id="accessSecondaryPassword" name="secondaryPassword" class="input-brutal w-full px-4 py-3" placeholder="Dictionary word" />
          </div>
          <button type="submit" class="btn-brutal btn-brutal-primary w-full py-4 mt-2 font-bold text-base">
            Access Note
          </button>
        </form>
        <div id="accessNoteError" class="hidden bg-red-100 border-2 border-red-500 text-red-800 p-4 mt-4 font-mono text-sm"></div>
      </div>
    </div>

    <!-- Save PDF Modal -->
    <div id="savePdfModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
      <div class="modal-content-swiss max-w-md w-full mx-4">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl font-extrabold uppercase font-display text-black dark:text-white">
            Save PDF to Notes
          </h3>
          <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
        </div>
        <form id="savePdfForm" class="space-y-4">
          <div>
            <label for="pdfTitle" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Note Title:</label>
            <input type="text" id="pdfTitle" name="title" required maxlength="100" class="input-brutal w-full px-4 py-3" placeholder="Chat Export - Room ABC123" />
          </div>
          <div>
            <label for="pdfPrimaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Primary Password:</label>
            <input type="text" id="pdfPrimaryPassword" name="primaryPassword" required class="input-brutal w-full px-4 py-3" placeholder="Dictionary word" />
          </div>
          <div>
            <label for="pdfSecondaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Secondary Password (Optional):</label>
            <input type="text" id="pdfSecondaryPassword" name="secondaryPassword" class="input-brutal w-full px-4 py-3" placeholder="Dictionary word" />
          </div>
          <div class="flex gap-3 mt-2">
            <button type="button" id="cancelPdfSave" class="btn-brutal btn-brutal-white flex-1 py-3 text-sm font-bold">
              Cancel
            </button>
            <button type="submit" class="btn-brutal btn-brutal-primary flex-1 py-3 text-sm font-bold">
              Save PDF
            </button>
          </div>
        </form>
        <div id="savePdfError" class="hidden bg-red-100 border-2 border-red-500 text-red-800 p-4 mt-4 font-mono text-sm"></div>
      </div>
    </div>

    <!-- My Notes List Modal -->
    <div id="myNotesModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
      <div class="modal-content-swiss max-w-4xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl md:text-3xl font-extrabold uppercase font-display text-black dark:text-white">
            My Notes
          </h3>
          <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
        </div>
        <div id="notesListContainer" class="space-y-4 text-black dark:text-white">
          <div class="text-center text-gray-500 py-8 font-mono">Loading notes...</div>
        </div>
      </div>
    </div>

    <!-- Toast Container -->
    <div id="toastContainer" class="fixed top-20 right-4 z-[10000] space-y-3" style="pointer-events: none"></div>

    <script src="/js/notes.js"></script>
    <script>
      // Theme toggle functionality
      const themeToggle = document.getElementById("themeToggle");
      const themeText = document.getElementById("themeText");

      // Check for saved theme preference or default to light
      const currentTheme = localStorage.getItem("theme") || "light";

      // Apply theme on page load
      if (currentTheme === "dark") {
        document.documentElement.classList.add("dark");
        themeText.textContent = "LIGHT";
      } else {
        themeText.textContent = "DARK";
      }

      // Theme toggle event listener
      themeToggle.addEventListener("click", () => {
        const isDark = document.documentElement.classList.contains("dark");

        if (isDark) {
          // Switch to light theme
          document.documentElement.classList.remove("dark");
          themeText.textContent = "DARK";
          localStorage.setItem("theme", "light");
        } else {
          // Switch to dark theme
          document.documentElement.classList.add("dark");
          themeText.textContent = "LIGHT";
          localStorage.setItem("theme", "dark");
        }
      });
    </script>
  </body>
</html>
