        <!-- Features Grid -->
        <section class="mb-16 md:mb-24 px-4">
            <h3 class="text-3xl md:text-5xl font-extrabold text-center mb-12 md:mb-16 font-display uppercase tracking-tight">Key Features</h3>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
                <div class="card-brutal p-6 md:p-8">
                    <div class="text-3xl mb-4 font-bold">◉</div>
                    <h4 class="text-lg md:text-xl font-bold mb-4 font-display">Secure Authentication</h4>
                    <p class="text-gray-600 dark:text-gray-300 text-sm md:text-base">JWT-based authentication system for secure access</p>
                </div>
                
                <div class="card-brutal p-6 md:p-8">
                    <div class="text-3xl mb-4 font-bold">◐</div>
                    <h4 class="text-lg md:text-xl font-bold mb-4 font-display">Ephemeral Rooms</h4>
                    <p class="text-gray-600 dark:text-gray-300 text-sm md:text-base">Temporary rooms that auto-destroy based on user-defined rules</p>
                </div>
                
