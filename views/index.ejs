                    <h4 class="text-lg md:text-xl font-bold mb-4 font-display">Democratic Voting</h4>
                    <p class="text-gray-600 dark:text-gray-300 text-sm md:text-base">Member voting system for admission control</p>
                </div>
                
                <div class="card-brutal p-6 md:p-8">
                    <div class="text-3xl mb-4 font-bold">▦</div>
