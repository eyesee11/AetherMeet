                        <h4 class="text-2xl md:text-3xl font-extrabold mb-3 font-display">Demo Rooms</h4>
                        <p class="text-gray-700 font-medium">Try instantly, no signup required</p>
                    </div>
                    <div class="space-y-3 mb-8">
                        <div class="flex items-center gap-3">
