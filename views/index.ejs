                    <img src="/logo.jpg" alt="AetherMeet Logo" class="h-8 w-8 md:h-10 md:w-10 object-contain">
                </div>
                <div>
                    <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold tracking-normal font-display">AetherMeet</h1>
                    <p class="text-xs md:text-sm text-gray-600 dark:text-gray-400 font-mono font-medium hidden sm:block" data-i18n="common.tagline">Secure & Ephemeral Team Chat Rooms</p>
                </div>
            </div>
            <div class="flex md:hidden items-center space-x-3">
                <button id="tryDemoBtnMobile" class="btn-brutal btn-brutal-primary px-4 py-2 text-xs flex-1">
                    Demo
                </button>
                <button id="headerGetStartedBtnMobile" class="btn-brutal btn-brutal-black px-4 py-2 text-xs flex-1">
                    Sign Up
                </button>
            </div>
            <div class="hidden md:flex items-center space-x-4">
