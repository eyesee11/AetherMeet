    <script src="/js/i18n-frontend.js"></script>
    <script src="/js/auth.js"></script>
    <script>
        // Theme toggle functionality
        const themeToggle = document.getElementById('themeToggle');
        const themeText = document.getElementById('themeText');
        
        // Check for saved theme preference or default to light
        const currentTheme = localStorage.getItem('theme') || 'light';
        
        // Apply theme on page load
        if (currentTheme === 'dark') {
            document.documentElement.classList.add('dark');
            themeText.textContent = 'LIGHT';
        }
        
        // Theme toggle event listener
        themeToggle.addEventListener('click', () => {
            const isDark = document.documentElement.classList.contains('dark');
            
            if (isDark) {
                // Switch to light theme
                document.documentElement.classList.remove('dark');
                themeText.textContent = 'DARK';
                localStorage.setItem('theme', 'light');
            } else {
                // Switch to dark theme
                document.documentElement.classList.add('dark');
                themeText.textContent = 'LIGHT';
                localStorage.setItem('theme', 'dark');
            }
        });

        // Primary Demo button functionality
        document.getElementById('demoBtn')?.addEventListener('click', async () => {
            await createDemoRoom(document.getElementById('demoBtn'));
        });

        // Demo button functionality (existing)
        document.getElementById('tryDemoBtn')?.addEventListener('click', async () => {
            await createDemoRoom(document.getElementById('tryDemoBtn'));
        });

        // "Choose Your Experience" section - Start Demo Now button
        document.getElementById('startDemoNowBtn')?.addEventListener('click', async () => {
            await createDemoRoom(document.getElementById('startDemoNowBtn'));
        });

        // "Choose Your Experience" section - Sign Up Free button
        document.getElementById('signUpFreeBtn')?.addEventListener('click', () => {
            const registerModal = document.getElementById('registerModal');
            if (registerModal) {
                registerModal.classList.remove('hidden');
            }
        });

        // Mobile header buttons
        document.getElementById('tryDemoBtnMobile')?.addEventListener('click', async () => {
            await createDemoRoom(document.getElementById('tryDemoBtnMobile'));
        });

        document.getElementById('headerGetStartedBtnMobile')?.addEventListener('click', () => {
            const registerModal = document.getElementById('registerModal');
            if (registerModal) {
                registerModal.classList.remove('hidden');
            }
        });

        // Shared demo room creation function
        async function createDemoRoom(button) {
            try {
                // Disable button and show loading state
                const originalText = button.textContent;
                button.disabled = true;
                
                // Use translation if available, fallback to default
                const creatingText = 'Creating...';
                button.textContent = creatingText;

                // Create demo room
                const response = await fetch('/api/rooms/create-demo', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                if (data.success) {
                    // Redirect to the demo room
                    window.location.href = `/room/${data.roomCode}?demo=true`;
                } else {
                    const errorMessage = window.i18n ? 
                        window.i18n.translate('error.createDemoRoom') + ': ' + data.message :
                        'Failed to create demo room: ' + data.message;
                    alert(errorMessage);
                    button.disabled = false;
                    button.textContent = originalText;
                }
            } catch (error) {
                console.error('Demo room creation error:', error);
                const errorMessage = window.i18n ? 
                    window.i18n.translate('error.createDemoRoomGeneric') : 
                    'Failed to create demo room. Please try again.';
                alert(errorMessage);
                button.disabled = false;
                button.textContent = originalText;
            }
        }
    </script>
</body>
</html>
