    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AetherMeet - Secure & Ephemeral Team Chat Rooms</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/compiled.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        'mono': ['JetBrains Mono', 'Consolas', 'Monaco', 'Courier New', 'monospace'],
                        'sans': ['Outfit', 'Helvetica Neue', 'Helvetica', 'Arial', 'sans-serif'],
                        'display': ['Space Grotesk', 'Helvetica Neue', 'Helvetica', 'Arial', 'sans-serif']
                    },
                    spacing: {
                        '4.5': '1.125rem',
                        '5.5': '1.375rem',
                        '6.5': '1.625rem'
                    }
                }
            }
        }
    </script>
    <style>
        /* Base typography overrides */
        h1, h2, h3, h4 {
