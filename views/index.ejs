                    <div class="text-center mb-8">
                        <h4 class="text-2xl md:text-3xl font-extrabold mb-3 font-display">Full Access</h4>
                        <p class="text-gray-700 font-medium">Complete features with your account</p>
                    </div>
                    <div class="space-y-3 mb-8">
                        <div class="flex items-center gap-3">
                            <span class="text-green-700 font-extrabold text-lg">✓</span>
                            <span class="font-mono text-sm font-bold">All Demo Features</span>
                        </div>
                        <div class="flex items-center gap-3">
