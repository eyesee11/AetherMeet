                    <h3 class="text-xl md:text-2xl font-bold mb-6 font-display">1. What do you wish to create?</h3>
                    <div class="bg-gray-50 dark:bg-zinc-800 border-2 border-black dark:border-white p-6">
                        <div class="mb-4">
                            <span class="font-mono text-sm font-bold">ROOM NAME:</span>
                            <p class="font-mono text-sm mt-2">BreakUp Party @9</p>
                        </div>
                        <div>
                            <span class="font-mono text-sm font-bold">NEED:</span>
                            <p class="font-mono text-sm mt-2">#Want a temporary room with high security just to mock the friend</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Response Card -->
            <div class="card-brutal p-8 md:p-12">
                <div class="mb-8">
                    <h3 class="text-xl md:text-2xl font-bold mb-6 font-display">2. Your Instant Room & Data</h3>
