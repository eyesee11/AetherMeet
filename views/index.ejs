    <!-- Login Modal -->
    <div id="loginModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
        <div class="modal-content-swiss max-w-md w-full mx-4">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-bold tracking-tight uppercase font-display text-black dark:text-white">Login</h3>
                <button class="close text-2xl font-black text-black dark:text-white">&times;</button>
            </div>
            <form id="loginForm" class="space-y-4">
                <div>
                    <label for="loginUsername" class="block text-sm font-bold mb-2 uppercase text-black dark:text-white">Username or Email:</label>
                    <input type="text" id="loginUsername" name="username" required class="input-swiss w-full px-4 py-3 text-black dark:text-white">
                </div>
                <div>
                    <label for="loginPassword" class="block text-sm font-bold mb-2 uppercase text-black dark:text-white">Password:</label>
