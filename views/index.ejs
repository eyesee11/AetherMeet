                    </button>
                    <button id="loginBtn2" class="btn-brutal btn-brutal-white px-4 md:px-6 py-4 text-sm md:text-base flex-1 md:flex-none" data-i18n="auth.signIn">
                        Sign In
                    </button>
                </div>
            </div>
        </div>

        <!-- Demo Section -->
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 mb-16 md:mb-24 px-4">
            <!-- Request Card -->
            <div class="card-brutal p-8 md:p-12">
