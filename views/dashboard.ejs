<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - AetherMeet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Emoji:wght@300..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/compiled.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        'mono': ['JetBrains Mono', 'Consolas', 'Monaco', 'Courier New', 'monospace'],
                        'sans': ['Outfit', 'Helvetica Neue', 'Helvetica', 'Arial', 'sans-serif'],
                        'display': ['Space Grotesk', 'Helvetica Neue', 'Helvetica', 'Arial', 'sans-serif']
                    },
                    spacing: {
                        '4.5': '1.125rem',
                        '5.5': '1.375rem',
                        '6.5': '1.625rem'
                    }
                }
            }
        }
    </script>
    <style>
        /* Emoji font styling */
        .emoji, #themeIcon, [data-emoji], 
        .theme-toggle-btn span,
        .pdf-export-btn span,
        button span[role="img"],
        [aria-label*="emoji"] {
            font-family: 'Noto Emoji', 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif !important;
            font-variation-settings: 'wght' 400;
        }
        
        /* Local display fonts */
        h1, h2, h3, h4 {
            font-family: 'Space Grotesk', sans-serif !important;
        }
        
        /* Logo styling */
        .logo img {
            border: 2px solid #000000;
        }
        html.dark .logo img {
            border: 2px solid #FFFFFF;
        }
    </style>
</head>
<body class="bg-white text-black font-sans min-h-screen transition-colors duration-300 dark:bg-zinc-950 dark:text-white">
    <!-- Theme Toggle -->
    <div class="fixed top-2 right-2 md:top-4 md:right-4 z-50">
        <button id="themeToggle" class="btn-brutal btn-brutal-white px-2 py-1.5 md:px-4 md:py-2 text-xs md:text-sm">
            <span id="themeText">DARK</span>
        </button>
    </div>

    <!-- Header -->
    <header class="px-4 md:px-6 py-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center flex-wrap gap-4">
            <div class="flex items-center space-x-2 md:space-x-4">
                <div class="logo bg-white p-1">
                    <img src="/logo.jpg" alt="AetherMeet Logo" class="h-8 w-8 md:h-10 md:w-10 lg:h-12 lg:w-12 object-contain" style="display: block;">
                </div>
                <div>
                    <h1 class="text-xl md:text-2xl lg:text-3xl font-extrabold tracking-tight font-display">AetherMeet</h1>
                    <p class="text-xs md:text-sm text-gray-600 dark:text-gray-400 font-mono">Dashboard</p>
                </div>
            </div>
            <div class="flex items-center space-x-2 md:space-x-4 flex-wrap">
                <span id="welcomeUser" class="font-mono text-xs md:text-sm hidden sm:block font-bold">Welcome, User!</span>
                <a href="/notes" class="btn-brutal btn-brutal-primary px-3 py-1.5 md:px-4 md:py-2 text-xs md:text-sm">
                    Notes
                </a>
                <button id="logoutBtn" class="btn-brutal btn-brutal-white px-3 py-1.5 md:px-4 md:py-2 text-xs md:text-sm">
                    Logout
                </button>
            </div>
        </div>
    </header>

    <!-- Main Dashboard -->
    <main class="max-w-6xl mx-auto px-4 md:px-6 py-8 md:py-12">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            <!-- Create Room Section -->
            <section class="card-brutal p-6">
                <h2 class="text-xl font-bold tracking-tight mb-6 font-display uppercase">Create New Room</h2>
                <div class="space-y-4">
                    <button id="createInstantBtn" class="btn-brutal btn-brutal-black w-full px-6 py-3 text-sm">
                        Create Instant Room
                    </button>
                    <button id="createScheduledBtn" class="btn-brutal btn-brutal-white w-full px-6 py-3 text-sm">
                        Schedule Room
                    </button>
                </div>
            </section>

            <!-- Join Room Section -->
            <section class="card-brutal p-6">
                <h2 class="text-xl font-bold tracking-tight mb-6 font-display uppercase">Join Room</h2>
                <form id="joinRoomForm" class="space-y-4">
                    <div>
                        <label for="roomCode" class="block text-xs font-bold uppercase mb-2">Room Code:</label>
                        <input type="text" id="roomCode" name="roomCode" placeholder="Enter 6-digit room code" maxlength="6" required 
                               value="<%= typeof roomCode !== 'undefined' ? roomCode : '' %>"
                               class="input-brutal w-full px-4 py-3 uppercase">
                    </div>
                    <button type="submit" class="btn-brutal btn-brutal-black w-full px-6 py-3 text-sm">
                        Find Room
                    </button>
                </form>
            </section>

            <!-- My Rooms Section -->
            <section class="card-brutal p-6 md:col-span-2 lg:col-span-1">
                <h2 class="text-xl font-bold tracking-tight mb-6 font-display uppercase">My Rooms</h2>
                <div id="myRoomsList" class="space-y-3 max-h-64 overflow-y-auto">
                    <p class="text-gray-600 dark:text-gray-400 font-mono text-sm">Loading your rooms...</p>
                </div>
            </section>
        </div>
    </main>

    <!-- Footer -->
    <footer class="px-4 md:px-6 py-6 md:py-8 mt-8 md:mt-12">
        <div class="max-w-6xl mx-auto">
            <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
                <div class="flex items-center space-x-2 md:space-x-4">
                    <div class="bg-white p-1" style="border: 2px solid #000;">
                        <img src="/logo.jpg" alt="AetherMeet Logo" class="h-6 w-6 md:h-8 md:w-8 lg:h-10 lg:w-10 object-contain" style="display: block;">
                    </div>
                    <div>
                        <h3 class="text-base md:text-xl font-bold font-display">AetherMeet</h3>
                        <p class="text-xs text-gray-600 dark:text-gray-400 font-mono">Secure & Ephemeral Team Chat Rooms</p>
                    </div>
                </div>
                <div class="text-center md:text-right">
                    <p class="text-xs md:text-sm font-mono text-gray-600 dark:text-gray-400">&copy; 2025 AetherMeet. All rights reserved.</p>
                    <p class="text-xs font-mono text-gray-500 dark:text-gray-500 mt-1">Built with security and privacy in mind Fr. ▣</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Create Instant Room Modal -->
    <div id="instantRoomModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
        <div class="modal-content-swiss max-w-lg w-full mx-4 max-h-screen overflow-y-auto transform transition-all duration-300">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl md:text-3xl font-extrabold uppercase font-display text-black dark:text-white">⚡ Create Instant Room</h3>
                <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
            </div>
            <form id="instantRoomForm" class="space-y-5">
                <div>
                    <label for="instantRoomName" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">🏠 Room Name:</label>
                    <input type="text" id="instantRoomName" name="name" required 
                           class="input-brutal w-full px-4 py-3"
                           placeholder="Enter your room name">
                </div>
                <div>
                    <label for="instantRoomDescription" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Description (Optional):</label>
                    <textarea id="instantRoomDescription" name="description" rows="3"
                              class="input-brutal w-full px-4 py-3"
                              placeholder="Describe what this room is for..."></textarea>
                </div>
                <div>
                    <label for="instantPrimaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">🔑 Primary Password:</label>
                    <input type="text" id="instantPrimaryPassword" name="primaryPassword" required 
                           class="input-brutal w-full px-4 py-3"
                           placeholder="Enter dictionary word">
                    <small class="text-xs font-bold uppercase bg-yellow-100 text-yellow-800 dark:bg-yellow-950/40 dark:text-yellow-400 px-2.5 py-1 border border-yellow-400 inline-block mt-2 font-mono">📚 Must be a valid English dictionary word</small>
                </div>
                <div>
                    <label for="instantSecondaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Secondary Password (Optional):</label>
                    <input type="text" id="instantSecondaryPassword" name="secondaryPassword" 
                           class="input-brutal w-full px-4 py-3"
                           placeholder="Optional second word">
                    <small class="text-xs font-bold uppercase bg-blue-100 text-blue-800 dark:bg-blue-950/40 dark:text-blue-400 px-2.5 py-1 border border-blue-400 inline-block mt-2 font-mono">📖 Also must be a valid English dictionary word</small>
                </div>
                <div>
                    <label for="instantAdmissionType" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">🚪 Admission Control:</label>
                    <select id="instantAdmissionType" name="admissionType" 
                            class="input-brutal w-full px-4 py-3 font-mono">
                        <option value="owner_approval">👑 Owner Approval</option>
                        <option value="democratic_voting">Democratic Voting</option>
                    </select>
                </div>
                <button type="submit" class="btn-brutal btn-brutal-primary w-full py-4 mt-2 font-bold text-base">
                    ⚡ CREATE ROOM NOW
                </button>
            </form>
            <div id="instantRoomError" class="hidden bg-red-100 border-2 border-red-500 text-red-800 p-4 mt-4 font-mono text-sm font-bold">
                <span class="font-black">ERROR:</span> <span id="instantRoomErrorText"></span>
            </div>
        </div>
    </div>

    <!-- Create Scheduled Room Modal -->
    <div id="scheduledRoomModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
        <div class="modal-content-swiss max-w-lg w-full mx-4 max-h-screen overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-extrabold uppercase font-display text-black dark:text-white">📅 Schedule Room</h3>
                <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
            </div>
            <form id="scheduledRoomForm" class="space-y-4">
                <div>
                    <label for="scheduledRoomName" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Room Name:</label>
                    <input type="text" id="scheduledRoomName" name="name" required class="input-brutal w-full px-4 py-3">
                </div>
                <div>
                    <label for="scheduledRoomDescription" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Description (Optional):</label>
                    <textarea id="scheduledRoomDescription" name="description" rows="3" class="input-brutal w-full px-4 py-3"></textarea>
                </div>
                <div>
                    <label for="scheduledTime" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Scheduled Time:</label>
                    <input type="datetime-local" id="scheduledTime" name="scheduledTime" required class="input-brutal w-full px-4 py-3 font-mono">
                </div>
                <div>
                    <label for="scheduledPrimaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Primary Password:</label>
                    <input type="text" id="scheduledPrimaryPassword" name="primaryPassword" required class="input-brutal w-full px-4 py-3">
                    <small class="text-gray-500 text-xs font-mono block mt-1">Must be a valid English dictionary word</small>
                </div>
                <div>
                    <label for="scheduledSecondaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Secondary Password (Optional):</label>
                    <input type="text" id="scheduledSecondaryPassword" name="secondaryPassword" class="input-brutal w-full px-4 py-3">
                    <small class="text-gray-500 text-xs font-mono block mt-1">Also must be a valid English dictionary word</small>
                </div>
                <div>
                    <label for="scheduledAdmissionType" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Admission Control:</label>
                    <select id="scheduledAdmissionType" name="admissionType" class="input-brutal w-full px-4 py-3 font-mono">
                        <option value="owner_approval">Owner Approval</option>
                        <option value="democratic_voting">Democratic Voting</option>
                    </select>
                </div>
                <button type="submit" class="btn-brutal btn-brutal-primary w-full py-4 mt-2 font-bold text-base">
                    Schedule Room
                </button>
            </form>
            <div id="scheduledRoomError" class="hidden bg-red-100 border-2 border-red-500 text-red-800 p-4 mt-4 font-mono text-sm"></div>
        </div>
    </div>

    <!-- Join Room Details Modal -->
    <div id="joinRoomModal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 hidden">
        <div class="modal-content-swiss max-w-md w-full mx-4">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-extrabold uppercase font-display text-black dark:text-white">Join Room</h3>
                <button class="close btn-brutal btn-brutal-danger px-3 py-1 text-xl font-bold">&times;</button>
            </div>
            <div id="roomDetails" class="mb-6 bg-gray-50 dark:bg-zinc-800 p-4 border border-black dark:border-white font-mono text-sm"></div>
            <form id="joinRoomPasswordForm" class="space-y-4">
                <div>
                    <label for="joinPrimaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Primary Password:</label>
                    <input type="text" id="joinPrimaryPassword" name="primaryPassword" required class="input-brutal w-full px-4 py-3">
                </div>
                <div id="secondaryPasswordGroup" class="hidden">
                    <label for="joinSecondaryPassword" class="block text-xs font-bold uppercase mb-2 text-black dark:text-white">Secondary Password:</label>
                    <input type="text" id="joinSecondaryPassword" name="secondaryPassword" class="input-brutal w-full px-4 py-3">
                </div>
                <button type="submit" class="btn-brutal btn-brutal-primary w-full py-4 mt-2 font-bold text-base">
                    Join Room
                </button>
            </form>
            <div id="joinRoomError" class="hidden bg-red-100 border-2 border-red-500 text-red-800 p-4 mt-4 font-mono text-sm"></div>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
    <script>
        // Auto-trigger room lookup if room code is pre-filled from share link
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Dashboard page loaded');
            const roomCodeInput = document.getElementById('roomCode');
            if (roomCodeInput && roomCodeInput.value && roomCodeInput.value.trim().length === 6) {
                console.log('Auto-triggering room lookup for code:', roomCodeInput.value);
                // Auto-trigger the form submission to check room and show password modal
                setTimeout(() => {
                    const joinForm = document.getElementById('joinRoomForm');
                    if (joinForm) {
                        joinForm.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
                    }
                }, 500);
            }
        });
    </script>

    <!-- Socket.IO for real-time admission notifications -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // Connect to socket for admission result notifications
        const dashboardToken = localStorage.getItem('token');
        if (dashboardToken) {
            const socket = io({
                auth: { token: dashboardToken }
            });

            // Listen for admission results
            socket.on('admissionResult', (data) => {
                const socketUser = JSON.parse(localStorage.getItem('user'));
                if (data.username === socketUser.username) {
                    if (data.result === 'admitted') {
                        alert('You have been admitted to the room!');
                        window.location.href = `/room/${data.roomCode}`;
                    } else {
                        alert('Your admission request was denied.');
                    }
                }
            });

            // Handle connection errors
            socket.on('connect_error', (error) => {
                console.error('Socket connection error:', error);
            });
        }
        
        // Theme toggle functionality
        const themeToggle = document.getElementById('themeToggle');
        const themeText = document.getElementById('themeText');
        
        // Ensure elements exist before proceeding
        if (themeToggle && themeText) {
            // Check for saved theme preference or default to light
            const currentTheme = localStorage.getItem('theme') || 'light';
            
            // Apply theme on page load
            if (currentTheme === 'dark') {
                document.documentElement.classList.add('dark');
                themeText.textContent = 'LIGHT';
            } else {
                document.documentElement.classList.remove('dark');
                themeText.textContent = 'DARK';
            }
            
            // Theme toggle event listener
            themeToggle.addEventListener('click', () => {
                const isDark = document.documentElement.classList.contains('dark');
                
                if (isDark) {
                    // Switch to light theme
                    document.documentElement.classList.remove('dark');
                    themeText.textContent = 'DARK';
                    localStorage.setItem('theme', 'light');
                } else {
                    // Switch to dark theme
                    document.documentElement.classList.add('dark');
                    themeText.textContent = 'LIGHT';
                    localStorage.setItem('theme', 'dark');
                }
            });
        } else {
            console.error('Theme toggle elements not found');
        }
    </script>
</body>
</html>
